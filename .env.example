# Overleaf Session Cookie
# Get this value from your browser:
# 1. Open https://www.overleaf.com
# 2. Log in to your account
# 3. Open Developer Tools (F12)
# 4. Go to Application → Cookies → https://www.overleaf.com
# 5. Find "overleaf_session2" and copy its value
# 6. Paste it here

OVERLEAF_SESSION_COOKIE=your_cookie_value_here
